# Google Search Console (posicionamiento SEO)
GSC_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# SerpAPI
SERPAPI_KEY=xxxxxxxxxxxxxxxxxxxx

# Google Gemini (capa LLM: categorización, reescritura de títulos/metas)
# Key en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxx

# OpenRouter (capa LLM, proveedor PREFERIDO desde 2026-07-10 — reemplaza a
# Bedrock, que la cuenta AWS del usuario no puede invocar). Key en
# https://openrouter.ai/keys. Modelo default: tencent/hy3:free (gratis en
# OpenRouter, ver comentario en agent/config.py sobre vigencia de la promo).
OPENROUTER_API_KEY=xxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=tencent/hy3:free

